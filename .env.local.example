# ─── EmailJS (contact form) ───
# Sign up at https://www.emailjs.com/ and grab these from your dashboard
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_API=your_public_key

# ─── OpenRouter (AI chatbot) ───
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-open-api-key-here

# Choose any model from https://openrouter.ai/models
# Free options: arcee-ai/trinity-large-preview:free, nvidia/nemotron-nano-9b-v2:free
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
